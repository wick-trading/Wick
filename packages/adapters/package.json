{
  "name": "@wick/adapters",
  "version": "0.0.1",
  "description": "Exchange adapters that map WebSocket feeds to Vela data types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./binance": {
      "types": "./dist/binance.d.ts",
      "default": "./dist/binance.js"
    },
    "./coinbase": {
      "types": "./dist/coinbase.d.ts",
      "default": "./dist/coinbase.js"
    },
    "./kraken": {
      "types": "./dist/kraken.d.ts",
      "default": "./dist/kraken.js"
    },
    "./bybit": {
      "types": "./dist/bybit.d.ts",
      "default": "./dist/bybit.js"
    },
    "./okx": {
      "types": "./dist/okx.d.ts",
      "default": "./dist/okx.js"
    },
    "./dydx": {
      "types": "./dist/dydx.d.ts",
      "default": "./dist/dydx.js"
    },
    "./bitfinex": {
      "types": "./dist/bitfinex.d.ts",
      "default": "./dist/bitfinex.js"
    },
    "./gateio": {
      "types": "./dist/gateio.d.ts",
      "default": "./dist/gateio.js"
    },
    "./mexc": {
      "types": "./dist/mexc.d.ts",
      "default": "./dist/mexc.js"
    },
    "./kucoin": {
      "types": "./dist/kucoin.d.ts",
      "default": "./dist/kucoin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/astralchemist/vela",
    "directory": "packages/adapters"
  },
  "homepage": "https://github.com/astralchemist/vela#readme",
  "keywords": [
    "trading",
    "web-components",
    "headless",
    "orderbook",
    "real-time",
    "adapters",
    "websocket",
    "exchange",
    "binance",
    "coinbase"
  ],
  "author": "astralchemist",
  "dependencies": {
    "@wick/core": "0.0.1"
  },
  "license": "MIT"
}
