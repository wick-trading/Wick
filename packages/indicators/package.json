{
  "name": "@wick/indicators",
  "version": "0.0.2",
  "description": "Headless technical indicator overlays for @wick/candlestick-chart — EMA, SMA, Bollinger, MACD, RSI, VWAP",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
